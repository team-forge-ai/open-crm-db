# Picardo Internal DB — environment configuration
#
# Copy to .env and fill in. Never commit real credentials.

# Postgres connection string. Format: postgres://user:pass@host:port/database
# Example for a local dev DB created with `createdb picardo_internal_db_dev`:
DATABASE_URL=postgres://localhost/picardo_internal_db_dev

# Optional: name of the table node-pg-migrate uses to track applied migrations.
# Defaults to "pgmigrations" if unset.
# PICARDO_DB_MIGRATIONS_TABLE=pgmigrations

# Optional: schema for the migrations table. Defaults to "public".
# PICARDO_DB_MIGRATIONS_SCHEMA=public

# Optional: local schema-only dump path refreshed after migrations.
# Defaults to "schema.sql" at the repo root.
# PICARDO_DB_SCHEMA_DUMP_PATH=schema.sql

# Optional: separate URL used by tests that need a live database.
# Tests that require Postgres are skipped if this is unset.
# PICARDO_DB_TEST_URL=postgres://localhost/picardo_internal_db_test
